<?xml version="1.0" ?>
<!--
  =============================================================
  DODOMA CITY (TANZANIA) DRONE SIMULATION — Gazebo Harmonic
  Expanded urban environment with 50+ obstacle objects
  for drone obstacle avoidance training and testing
  =============================================================
  GPS: -6.1629, 35.7516, 1120m elevation
  Roads: India Road, Uhuru Street, Jamhuri Street, Azikiwe Street
  Landmarks: Bunge Parliament, Central Roundabout, City Garden
  =============================================================
-->
<sdf version="1.10">
  <world name="dodoma_tanzania">

    <!-- DODOMA GPS COORDINATES -->
    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>-6.1629</latitude_deg>
      <longitude_deg>35.7516</longitude_deg>
      <elevation>1120</elevation>
      <heading_deg>0</heading_deg>
    </spherical_coordinates>

    <!-- ============================================================ -->
    <!-- PHYSICS                                                       -->
    <!-- ============================================================ -->
    <physics type="ode">
      <real_time_update_rate>1000</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <gravity>0 0 -9.80665</gravity>
    </physics>

    <!-- ============================================================ -->
    <!-- SCENE SETTINGS                                                -->
    <!-- ============================================================ -->
    <scene>
      <ambient>0.4 0.4 0.45 1</ambient>
      <background>0.3 0.35 0.4 1</background>
      <sky>
        <time>12</time>
        <cloud_speed>0.03</cloud_speed>
      </sky>
      <shadows>true</shadows>
    </scene>

    <!-- ============================================================ -->
    <!-- LIGHT - Dodoma tropical sun (overhead, slightly south)        -->
    <!-- ============================================================ -->
    <light type="directional" name="sun">
      <pose>0 0 200 0 0 0</pose>
      <diffuse>1 1 0.95 1</diffuse>
      <specular>0.95 0.95 0.9 1</specular>
      <direction>-0.2 -0.1 -1</direction>
      <attenuation>
        <range>1000</range>
        <constant>0.5</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <cast_shadows>true</cast_shadows>
    </light>

    <!-- ============================================================ -->
    <!-- GROUND PLANE - Flat terrain with road surface                 -->
    <!-- ============================================================ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="ground_link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>1000 1000</size>
            </plane>
          </geometry>
        </collision>
        <visual name="ground_vis">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>1000 1000</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.65 0.6 0.5 1</ambient>
            <diffuse>0.7 0.65 0.55 1</diffuse>
            <specular>0.01 0.01 0.01 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- DRONE SPAWN PAD (at origin where x500 lands)                  -->
    <!-- ============================================================ -->
    <model name="spawn_pad">
      <pose>0 0 0.01 0 0 0</pose>
      <static>true</static>
      <link name="pad">
        <visual name="pad_vis">
          <geometry>
            <cylinder>
              <radius>1.5</radius>
              <length>0.02</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
          </material>
        </visual>
        <visual name="pad_marking">
          <pose>0 0 0.02 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>1.0</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.9 0.9 0.1 1</ambient>
            <diffuse>1 1 0.2 1</diffuse>
          </material>
        </visual>
        <visual name="cross_h">
          <pose>0 0 0.03 0 0 0</pose>
          <geometry>
            <box>
              <size>0.1 1.8 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>0 0 0 1</ambient>
            <diffuse>0 0 0 1</diffuse>
          </material>
        </visual>
        <visual name="cross_v">
          <pose>0 0 0.03 0 0 0</pose>
          <geometry>
            <box>
              <size>1.8 0.1 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>0 0 0 1</ambient>
            <diffuse>0 0 0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- ROAD NETWORK - Dodoma city streets                            -->
    <!-- ============================================================ -->

    <!-- EAST-WEST MAIN ROAD (India Road equivalent) -->
    <model name="ew_main_road">
      <pose>0 0 0.01 0 0 0</pose>
