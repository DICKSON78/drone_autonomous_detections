<?xml version="1.0" ?>
<!--
  =============================================================
  PUBG-STYLE DRONE WORLD — Gazebo Harmonic (gz-sim 8+)
  Kwa ajili ya Object Detection ya Drone (UAV)
  Mazingira ya kweli: PBR textures, real models, wind physics
  =============================================================
  JINSI YA KUANZISHA:
    gz sim worlds/pubg_reality.sdf

  MODELS ZINAZOHITAJIKA (download moja kwa moja):
    gz fuel download -u https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine%20Tree
    gz fuel download -u https://fuel.gazebosim.org/1.0/OpenRobotics/models/Oak%20Tree
    gz fuel download -u https://fuel.gazebosim.org/1.0/OpenRobotics/models/Construction%20Cone
    gz fuel download -u https://fuel.gazebosim.org/1.0/OpenRobotics/models/Lamp%20Post
  =============================================================
-->
<sdf version="1.10">
  <world name="pubg_drone_reality">

    <!-- =====================================================
         PLUGINS ZA GAZEBO HARMONIC
    ====================================================== -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-wind-effects-system"
            name="gz::sim::systems::WindEffects">
      <force_approximation_scaling_factor>1</force_approximation_scaling_factor>
      <horizontal>
        <magnitude>
          <time_for_rise>10</time_for_rise>
          <sin>
            <amplitude_percent>0.05</amplitude_percent>
            <period>60</period>
          </sin>
          <noise type="gaussian">
            <mean>0</mean>
            <stddev>0.1</stddev>
          </noise>
        </magnitude>
        <direction_deg>
          <time_for_rise>30</time_for_rise>
          <sin>
            <amplitude>5</amplitude>
            <period>20</period>
          </sin>
          <noise type="gaussian">
            <mean>0</mean>
            <stddev>0.5</stddev>
          </noise>
        </direction_deg>
      </horizontal>
      <vertical>
        <noise type="gaussian">
          <mean>0</mean>
          <stddev>0.01</stddev>
        </noise>
      </vertical>
    </plugin>

    <!-- =====================================================
         PHYSICS
    ====================================================== -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- =====================================================
         MWANGAZA WA KWELI (Realistic Lighting)
    ====================================================== -->

    <!-- Jua kuu — directional na shadows -->
    <light name="sun_directional" type="directional">
      <pose>0 0 500 0 0.4 0.8</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1.0</intensity>
      <direction>-0.5 0.3 -0.8</direction>
      <diffuse>1.0 0.95 0.85 1</diffuse>
      <specular>0.5 0.48 0.42 1</specular>
      <attenuation>
        <range>5000</range>
        <linear>0.0</linear>
        <constant>1.0</constant>
        <quadratic>0.0</quadratic>
      </attenuation>
    </light>

    <!-- Mwangaza wa anga (sky ambient) -->
    <light name="sky_ambient" type="directional">
      <pose>0 0 100 0 -1.5708 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>0.3</intensity>
      <direction>0 0 -1</direction>
      <diffuse>0.5 0.65 0.9 1</diffuse>
      <specular>0.0 0.0 0.0 1</specular>
    </light>

    <!-- =====================================================
         SCENE — OGRE2 PBR
    ====================================================== -->
    <scene>
      <ambient>0.3 0.32 0.35 1</ambient>
      <background>0.53 0.75 0.92 1</background>
      <sky>
        <clouds>
          <speed>12</speed>
        </clouds>
      </sky>
      <grid>false</grid>
      <origin_visual>false</origin_visual>
    </scene>

    <!-- =====================================================
         ARDHI YA KWELI — PBR Terrain (400x400m)
    ====================================================== -->
    <model name="terrain_ground">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>600 600</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.8</mu>
                <mu2>0.8</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>100</kd>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name="vis">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>600 600</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.35 0.38 0.22 1</ambient>
            <diffuse>0.38 0.42 0.24 1</diffuse>
            <specular>0.03 0.03 0.02 1</specular>
            <pbr>
              <metal>
                <albedo_map>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Grass%20Plane/tip/files/materials/textures/grass_color.jpg</albedo_map>
                <normal_map>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Grass%20Plane/tip/files/materials/textures/grass_normal.jpg</normal_map>
                <roughness_map>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Grass%20Plane/tip/files/materials/textures/grass_roughness.jpg</roughness_map>
                <metalness>0.0</metalness>
                <roughness>0.9</roughness>
              </metal>
            </pbr>
          </material>
          <plugin name="tile_uv" filename="gz-sim-shader-param-system">
          </plugin>
        </visual>
      </link>
    </model>

    <!-- =====================================================
         BARABARA ZA KWELI (PBR Asphalt Roads)
    ====================================================== -->

    <!-- Barabara kuu — Mashariki/Magharibi -->
    <model name="road_EW">
      <static>true</static>
      <pose>0 0 0.015 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>250 9 0.03</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 0 0 0 0</pose>
          <geometry><box><size>250 9 0.03</size></box></geometry>
          <material>
            <ambient>0.15 0.15 0.15 1</ambient>
            <diffuse>0.18 0.18 0.18 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
            <pbr>
              <metal>
                <metalness>0.0</metalness>
                <roughness>0.95</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- Mstari wa kati wa njia (Center line) -->
    <model name="road_centerline_EW">
      <static>true</static>
      <pose>0 0 0.032 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>245 0.25 0.005</size></box></geometry>
          <material>
            <ambient>0.85 0.78 0.1 1</ambient>
            <diffuse>0.9 0.82 0.12 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Barabara ya pili — Kaskazini/Kusini -->
    <model name="road_NS">
      <static>true</static>
      <pose>0 0 0.015 0 0 1.5708</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>250 9 0.03</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>250 9 0.03</size></box></geometry>
          <material>
            <ambient>0.15 0.15 0.15 1</ambient>
            <diffuse>0.18 0.18 0.18 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
            <pbr>
              <metal>
                <metalness>0.0</metalness>
                <roughness>0.95</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- =====================================================
         MITI — Kutoka Gazebo Fuel (Real 3D Models)
    ====================================================== -->

    <!-- Pine Trees - Miti ya Msunobari -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine%20Tree</uri>
      <name>pine_tree_1</name>
      <pose>18 25 0 0 0 0.3</pose>
    </include>

    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine%20Tree</uri>
      <name>pine_tree_2</name>
      <pose>-28 18 0 0 0 1.1</pose>
    </include>

    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine%20Tree</uri>
      <name>pine_tree_3</name>
      <pose>45 -15 0 0 0 2.4</pose>
    </include>

    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine%20Tree</uri>
      <name>pine_tree_4</name>
      <pose>-55 -35 0 0 0 0.7</pose>
    </include>

    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine%20Tree</uri>
      <name>pine_tree_5</name>
      <pose>65 42 0 0 0 1.8</pose>
    </include>

    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine%20Tree</uri>
      <name>pine_tree_6</name>
      <pose>-70 55 0 0 0 0.5</pose>
    </include>

    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine%20Tree</uri>
      <name>pine_tree_7</name>
      <pose>30 -65 0 0 0 2.1</pose>
    </include>

    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Pine%20Tree</uri>
      <name>pine_tree_8</name>
      <pose>-40 70 0 0 0 0.9</pose>
    </include>

    <!-- =====================================================
         MAJENGO YA KWELI (Realistic Buildings with PBR)
    ====================================================== -->

    <!-- === JENGO 1: Apartment Block Kubwa === -->
    <model name="apartment_block_A">
      <static>true</static>
      <pose>60 35 0 0 0 0.3</pose>
      <link name="foundation">
        <collision name="col">
          <geometry><box><size>22 16 0.4</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 0.2 0 0 0</pose>
          <geometry><box><size>22 16 0.4</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
            <pbr><metal><metalness>0.0</metalness><roughness>0.9</roughness></metal></pbr>
          </material>
        </visual>
      </link>
      <!-- Ghorofa ya 1 -->
      <link name="floor_1">
        <collision name="col">
          <pose>0 0 3 0 0 0</pose>
          <geometry><box><size>22 16 6</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 3 0 0 0</pose>
          <geometry><box><size>22 16 6</size></box></geometry>
          <material>
            <ambient>0.78 0.72 0.62 1</ambient>
            <diffuse>0.82 0.76 0.66 1</diffuse>
            <specular>0.08 0.08 0.07 1</specular>
            <pbr>
              <metal>
                <metalness>0.0</metalness>
                <roughness>0.85</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
      <!-- Ghorofa ya 2 -->
      <link name="floor_2">
        <collision name="col">
          <pose>0 0 9 0 0 0</pose>
          <geometry><box><size>22 16 6</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 9 0 0 0</pose>
          <geometry><box><size>22 16 6</size></box></geometry>
          <material>
            <ambient>0.74 0.68 0.58 1</ambient>
            <diffuse>0.78 0.72 0.62 1</diffuse>
            <specular>0.08 0.08 0.07 1</specular>
            <pbr>
              <metal>
                <metalness>0.0</metalness>
                <roughness>0.85</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
      <!-- Ghorofa ya 3 -->
      <link name="floor_3">
        <collision name="col">
          <pose>0 0 15 0 0 0</pose>
          <geometry><box><size>22 16 6</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 15 0 0 0</pose>
          <geometry><box><size>22 16 6</size></box></geometry>
          <material>
            <ambient>0.70 0.64 0.54 1</ambient>
            <diffuse>0.74 0.68 0.58 1</diffuse>
            <specular>0.08 0.08 0.07 1</specular>
            <pbr>
              <metal>
                <metalness>0.0</metalness>
                <roughness>0.85</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
      <!-- Dari ya juu (rooftop) -->
      <link name="rooftop">
        <visual name="vis">
          <pose>0 0 18.2 0 0 0</pose>
          <geometry><box><size>22.4 16.4 0.4</size></box></geometry>
          <material>
            <ambient>0.35 0.33 0.3 1</ambient>
            <diffuse>0.4 0.38 0.35 1</diffuse>
            <pbr><metal><metalness>0.05</metalness><roughness>0.9</roughness></metal></pbr>
          </material>
        </visual>
        <collision name="col">
          <pose>0 0 18.2 0 0 0</pose>
          <geometry><box><size>22.4 16.4 0.4</size></box></geometry>
        </collision>
      </link>
      <!-- Madirisha (window frames) - safu ya 1 -->
      <link name="windows_f1_front">
        <visual name="vis">
          <pose>0 8.02 3 0 0 0</pose>
          <geometry><box><size>18 0.1 4.5</size></box></geometry>
          <material>
            <ambient>0.15 0.25 0.45 0.7</ambient>
            <diffuse>0.2 0.35 0.6 0.7</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
            <pbr><metal><metalness>0.0</metalness><roughness>0.05</roughness></metal></pbr>
          </material>
        </visual>
      </link>
      <!-- Mlango mkuu -->
      <link name="door_main">
        <visual name="vis">
          <pose>0 8.03 1.5 0 0 0</pose>
          <geometry><box><size>2.2 0.08 3</size></box></geometry>
          <material>
            <ambient>0.3 0.2 0.1 1</ambient>
            <diffuse>0.35 0.25 0.15 1</diffuse>
            <pbr><metal><metalness>0.1</metalness><roughness>0.6</roughness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- === JENGO 2: Industrial Warehouse === -->
    <model name="warehouse_industrial">
      <static>true</static>
      <pose>-65 -25 0 0 0 0</pose>
      <link name="base">
        <collision name="col">
          <geometry><box><size>35 22 0.3</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 0.15 0 0 0</pose>
          <geometry><box><size>35 22 0.3</size></box></geometry>
          <material>
            <ambient>0.25 0.25 0.25 1</ambient>
            <diffuse>0.3 0.3 0.3 1</diffuse>
          </material>
        </visual>
      </link>
      <link name="walls">
        <collision name="col">
          <pose>0 0 5 0 0 0</pose>
          <geometry><box><size>35 22 10</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 5 0 0 0</pose>
          <geometry><box><size>35 22 10</size></box></geometry>
          <material>
            <ambient>0.5 0.5 0.48 1</ambient>
            <diffuse>0.55 0.55 0.53 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
            <pbr>
              <metal>
                <metalness>0.3</metalness>
                <roughness>0.7</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
      <!-- Paa la arch -->
      <link name="roof_arch">
        <collision name="col">
          <pose>0 0 10.6 0 0 0</pose>
          <geometry><box><size>35.4 22.4 1.2</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 10.6 0 0 0</pose>
          <geometry><box><size>35.4 22.4 1.2</size></box></geometry>
