        <collision name="col">
          <pose>-3.5 0 6.5 0 0.5 0</pose>
          <geometry><box><size>7 9.5 0.25</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>-3.5 0 6.5 0 0.5 0</pose>
          <geometry><box><size>7 9.5 0.25</size></box></geometry>
          <material>
            <ambient>0.52 0.22 0.15 1</ambient>
            <diffuse>0.58 0.26 0.18 1</diffuse>
            <pbr><metal><metalness>0.0</metalness><roughness>0.9</roughness></metal></pbr>
          </material>
        </visual>
      </link>
      <link name="roof_right">
        <collision name="col">
          <pose>3.5 0 6.5 0 -0.5 0</pose>
