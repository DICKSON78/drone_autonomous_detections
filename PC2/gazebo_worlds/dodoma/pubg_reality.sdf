    <!-- =====================================================
         GUI / CAMERA SETTINGS
    ====================================================== -->
    <gui fullscreen="0">
      <plugin filename="GzScene3D" name="3D View">
        <gz-gui>
          <title>3D View</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.3 0.32 0.35</ambient_light>
        <background_color>0.53 0.75 0.92</background_color>
        <camera_pose>-10 -30 25 0 0.6 0.8</camera_pose>
        <camera_clip>
          <near>0.25</near>
          <far>2000</far>
        </camera_clip>
      </plugin>
    </gui>

