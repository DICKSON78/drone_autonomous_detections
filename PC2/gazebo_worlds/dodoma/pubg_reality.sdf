            <pbr><metal><metalness>0.6</metalness><roughness>0.5</roughness></metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- === JENGO 3: Small House na Veranda === -->
    <model name="house_veranda">
      <static>true</static>
      <pose>-32 55 0 0 0 0.5</pose>
      <link name="base">
        <collision name="col">
          <geometry><box><size>12 9 0.3</size></box></geometry>
