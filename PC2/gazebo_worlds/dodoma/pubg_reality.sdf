    <!-- =====================================================
         MINARA YA KWELI (Realistic Towers)
    ====================================================== -->

    <!-- === MNARA WA MAWASILIANO (Cell Tower) === -->
    <model name="cell_tower_main">
      <static>true</static>
      <pose>35 -75 0 0 0 0</pose>
      <link name="base_platform">
        <collision name="col">
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>4 4 0.6</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>4 4 0.6</size></box></geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.4 0.4 0.4 1</diffuse>
            <pbr><metal><metalness>0.3</metalness><roughness>0.7</roughness></metal></pbr>
          </material>
        </visual>
      </link>
      <!-- Nguzo kuu -->
      <link name="main_pole">
        <collision name="col">
          <pose>0 0 20 0 0 0</pose>
          <geometry><cylinder><radius>0.35</radius><length>40</length></cylinder></geometry>
        </collision>
        <visual name="vis">
          <pose>0 0 20 0 0 0</pose>
          <geometry><cylinder><radius>0.35</radius><length>40</length></cylinder></geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.65 0.65 0.65 1</diffuse>
            <specular>0.3 0.3 0.3 1</specular>
            <pbr><metal><metalness>0.7</metalness><roughness>0.3</roughness></metal></pbr>
          </material>
        </visual>
      </link>
      <!-- Antenna panel 1 -->
      <link name="antenna_1">
        <collision name="col">
          <pose>0.6 0 38 0 0 0</pose>
          <geometry><box><size>0.15 0.3 2.5</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>0.6 0 38 0 0 0</pose>
          <geometry><box><size>0.15 0.3 2.5</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.55 1</ambient>
            <diffuse>0.6 0.6 0.6 1</diffuse>
            <pbr><metal><metalness>0.6</metalness><roughness>0.4</roughness></metal></pbr>
          </material>
        </visual>
      </link>
      <link name="antenna_2">
        <collision name="col">
          <pose>-0.3 0.52 38 0 0 2.094</pose>
          <geometry><box><size>0.15 0.3 2.5</size></box></geometry>
        </collision>
        <visual name="vis">
          <pose>-0.3 0.52 38 0 0 2.094</pose>
          <geometry><box><size>0.15 0.3 2.5</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.55 1</ambient>
            <diffuse>0.6 0.6 0.6 1</diffuse>
            <pbr><metal><metalness>0.6</metalness><roughness>0.4</roughness></metal></pbr>
          </material>
        </visual>
      </link>
      <link name="antenna_3">
        <collision name="col">
          <pose>-0.3 -0.52 38 0 0 -2.094</pose>
