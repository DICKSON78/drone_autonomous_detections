<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.9">
  <world name="dodoma_tanzania_realistic">

    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
      <gravity>0 0 -9.8066</gravity>
    </physics>
    
    <!-- Accurate Dodoma GPS coordinates -->
    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>-6.1630</latitude_deg>
      <longitude_deg>35.7516</longitude_deg>
      <elevation>1120</elevation>
      <heading_deg>0</heading_deg>
    </spherical_coordinates>

    <scene>
      <grid>false</grid>
      <sky>
        <time>14.0</time>
        <sunrise>6.2</sunrise>
        <sunset>18.3</sunset>
        <clouds>
          <speed>5</speed>
          <humidity>0.35</humidity>
          <mean_size>0.6</mean_size>
        </clouds>
      </sky>
      <ambient>0.52 0.52 0.52 1</ambient>
      <background>0.6 0.72 0.88 1</background>
      <shadows>true</shadows>
      <fog>
        <type>linear</type>
        <start>500</start>
        <end>1500</end>
        <density>0.0005</density>
      </fog>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 100 0 0 0</pose>
      <diffuse>1.0 0.98 0.92 1</diffuse>
      <specular>0.6 0.6 0.55 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.008</linear>
        <quadratic>0.0008</quadratic>
      </attenuation>
      <direction>-0.25 0.15 -0.96</direction>
    </light>

    <!-- Terrain with elevation variation -->
    <model name="terrain">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <heightmap>
              <size>2000 2000 50</size>
              <uri>file://media/materials/textures/dodoma_heightmap.png</uri>
              <texture>
                <size>1000 1000</size>
                <diffuse>file://media/materials/textures/dirt.png</diffuse>
                <normal>file://media/materials/textures/dirt_normal.png</normal>
              </texture>
            </heightmap>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- ============ REALISTIC ROAD NETWORK ============ -->
    
    <!-- Tarmac roads with lane markings -->
    <model name="road_a104_ew">
      <pose>0 0 0.15 0 0 0</pose>
      <static>true</static>
      <link name="link">
        <visual name="asphalt">
          <geometry>
            <box>
              <size>800 12 0.2</size>
            </box>
          </geometry>
          <material>
            <ambient>0.18 0.18 0.18 1</ambient>
