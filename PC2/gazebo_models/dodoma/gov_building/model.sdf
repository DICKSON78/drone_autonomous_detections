            <box>
              <size>800 0.15 0.03</size>
            </box>
          </geometry>
          <material>
            <ambient>0.95 0.85 0.15 1</ambient>
            <diffuse>1 0.9 0.2 1</diffuse>
            <emissive>0.3 0.25 0.05 1</emissive>
