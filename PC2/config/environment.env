# Environment variables for PC2 runtime configuration
# PC2 hosts Gazebo + PX4 SITL, Object Detection, RL Navigation

# IP address of PC1 (Kafka broker) - CHANGE THIS to your PC1's actual IP
PC1_IP=${PC1_IP:-192.168.1.101}

# Local PC IPs
PC2_IP=localhost
PC3_IP=${PC3_IP:-192.168.1.103}
PC4_IP=${PC4_IP:-192.168.1.104}

# Kafka connection (remote on PC1)
KAFKA_BOOTSTRAP_SERVERS=${PC1_IP}:9092
