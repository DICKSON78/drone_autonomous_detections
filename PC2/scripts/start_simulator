#!/bin/bash

# Gazebo Startup Script for Dodoma, Tanzania Environment
echo "🚁 Starting Gazebo with Dodoma, Tanzania Environment"
echo "=================================================="

# Check if Docker is running
if ! docker info > /dev/null 2>&1; then
    echo "❌ Docker is not running. Please start Docker first."
    exit 1
fi

# Check if fyp-network exists
if ! docker network ls | grep -q "fyp-network"; then
    echo "🌐 Creating fyp-network..."
    docker network create fyp-network
else
    echo "✅ fyp-network already exists"
fi

# Create Dodoma environment directory
mkdir -p ./gazebo_worlds/dodoma
mkdir -p ./gazebo_models/dodoma

# Stop existing Gazebo container if running
if docker ps -q -f name=gazebo-px4 | grep -q .; then
    echo "🛑 Stopping existing gazebo-px4 container..."
    docker stop gazebo-px4
    docker rm gazebo-px4
fi

echo "🌍 Creating Dodoma, Tanzania environment..."

# Create Dodoma world file
cat > ./gazebo_worlds/dodoma/dodoma_tanzania.world << 'EOF'
<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="dodoma_tanzania">
    
    <!-- Physics Engine Settings -->
    <physics name="1ms" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <gravity>0 0 -9.8066</gravity>
    </physics>

    <!-- Ground Plane - Dodoma Terrain -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Sun - Dodoma Climate (Hot and Dry) -->
    <include>
      <uri>model://sun</uri>
      <pose>0 0 50 0 0 0</pose>
    </include>
    
    <!-- Sky - Clear Dodoma Sky -->
    <scene>
      <sky>
        <time>10.0</time>
        <sunrise>6.0</sunrise>
        <sunset>18.5</sunset>
        <clouds>
          <speed>12</speed>
          <direction>1 0 0</direction>
          <humidity>0.3</humidity>
          <mean_size>0.5</mean_size>
          <ambient>0.4 0.4 0.4 1</ambient>
        </clouds>
      </sky>
    </scene>

    <!-- Dodoma Characteristic Vegetation - Acacia Trees -->
    <model name="acacia_tree_1">
      <pose>10 5 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.5</radius>
              <length>8</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.5</radius>
              <length>8</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.5 0.3 0.1 1</ambient>
            <diffuse>0.6 0.4 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="acacia_tree_2">
      <pose>-8 12 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.4</radius>
              <length>6</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.4</radius>
              <length>6</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.5 0.3 0.1 1</ambient>
            <diffuse>0.6 0.4 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Dodoma Buildings - Government Buildings Style -->
    <model name="gov_building_1">
      <pose>15 -10 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>20 15 12</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>20 15 12</size>
            </box>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.6 1</ambient>
            <diffuse>0.8 0.8 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Dodoma Characteristic - Small Hills/Rocky Outcrops -->
    <model name="rocky_hill_1">
      <pose>-15 -8 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <sphere>
              <radius>3</radius>
            </sphere>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <sphere>
              <radius>3</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.6 0.5 0.4 1</ambient>
            <diffuse>0.7 0.6 0.5 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Drone Starting Position -->
    <model name="drone_start">
      <pose>0 0 2 0 0 0</pose>
      <include>
        <uri>model://iris</uri>
      </include>
    </model>

    <!-- Wind Simulation - Dodoma Wind Patterns -->
    <wind>
      <linear_velocity>
        <x>2.5</x>
        <y>1.0</y>
        <z>0.0</z>
      </linear_velocity>
      <gust>
        <x>0.5</x>
        <y>0.3</y>
        <z>0.0</z>
      </gust>
    </wind>

  </world>
</sdf>
EOF

echo "🏢 Creating Dodoma building models..."

# Create Dodoma-style building model
mkdir -p ./gazebo_models/dodoma/gov_building
cat > ./gazebo_models/dodoma/gov_building/model.sdf << 'EOF'
<?xml version="1.0"?>
<sdf version="1.6">
  <model name="gov_building">
    <static>true</static>
    <link name="link">
      <collision name="collision">
        <geometry>
          <box>
            <size>20 15 12</size>
          </box>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <box>
            <size>20 15 12</size>
          </box>
        </geometry>
        <material>
          <ambient>0.7 0.7 0.6 1</ambient>
          <diffuse>0.8 0.8 0.7 1</diffuse>
        </material>
      </visual>
    </link>
  </model>
</sdf>
EOF

cat > ./gazebo_models/dodoma/gov_building/model.config << 'EOF'
<?xml version="1.0"?>
<model>
  <name>Government Building</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>PC2 Team</name>
    <email>pc2@fyp.com</email>
  </author>

  <description>
    Government building typical of Dodoma, Tanzania architecture
  </description>
</model>
EOF

echo "🌳 Creating Dodoma vegetation models..."

# Create Acacia tree model
mkdir -p ./gazebo_models/dodoma/acacia_tree
cat > ./gazebo_models/dodoma/acacia_tree/model.sdf << 'EOF'
<?xml version="1.0"?>
<sdf version="1.6">
  <model name="acacia_tree">
    <static>true</static>
    <link name="trunk">
      <pose>0 0 4 0 0 0</pose>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.5</radius>
            <length>8</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.5</radius>
            <length>8</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.5 0.3 0.1 1</ambient>
          <diffuse>0.6 0.4 0.2 1</diffuse>
        </material>
      </visual>
    </link>
  </model>
</sdf>
EOF

cat > ./gazebo_models/dodoma/acacia_tree/model.config << 'EOF'
<?xml version="1.0"?>
<model>
  <name>Acacia Tree</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>PC2 Team</name>
    <email>pc2@fyp.com</email>
  </author>

  <description>
    Acacia tree commonly found in Dodoma region, Tanzania
  </description>
</model>
EOF

echo "🚀 Starting Gazebo with Dodoma environment..."

# Start Gazebo with custom Dodoma world
docker run -d \
  --name gazebo-px4 \
  --network fyp-network \
  -p 14540:14540/udp \
  -p 14556:14556/udp \
  -v $(pwd)/gazebo_worlds:/gazebo_worlds \
  -v $(pwd)/gazebo_models:/gazebo_models \
  -v $(pwd)/px4_config:/px4_config \
  -e PX4_SIM_HOST=gazebo-px4 \
  -e PX4_SIM_PORT=14540 \
  -e GAZEBO_MODEL_PATH=/gazebo_models/dodoma:/usr/share/gazebo-11/models \
  -e GAZEBO_RESOURCE_PATH=/gazebo_worlds:/usr/share/gazebo-11 \
  --restart unless-stopped \
  px4io/px4-sitl-gazebo:latest \
  gazebo --verbose /gazebo_worlds/dodoma/dodoma_tanzania.world

# Wait for Gazebo to start
echo "⏳ Waiting for Gazebo to start..."
sleep 10

# Check if container is running
if docker ps -q -f name=gazebo-px4 | grep -q .; then
    echo "✅ Gazebo with Dodoma environment started successfully!"
    echo ""
    echo "📋 Environment Details:"
    echo "   • Location: Dodoma, Tanzania"
    echo "   • Climate: Hot and dry"
    echo "   • Vegetation: Acacia trees"
    echo "   • Buildings: Government architecture style"
    echo "   • Terrain: Rocky hills and flat plains"
    echo "   • Wind: Light breeze (2.5 m/s)"
    echo ""
    echo "🔗 Connection Info:"
    echo "   • MAVLink: localhost:14540"
    echo "   • MAVLink 2: localhost:14556"
    echo ""
    echo "🖥️ To open Gazebo GUI:"
    echo "   docker exec -it gazebo-px4 gazebo"
    echo ""
    echo "📊 Check status:"
    echo "   docker ps | grep gazebo-px4"
    echo "   docker logs gazebo-px4"
else
    echo "❌ Failed to start Gazebo container"
    echo "🔍 Check logs:"
    echo "   docker logs gazebo-px4"
    exit 1
fi
