# PC1 Environment Variables

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=drone-system
KAFKA_AUTO_OFFSET_RESET=latest

# Command Parser
COMMAND_PARSER_PORT=8000
NLP_MODEL=en_core_web_sm
NLP_CONFIDENCE_THRESHOLD=0.3

# Flight Controller
FLIGHT_CONTROL_PORT=8001
MAVLINK_SYSTEM_ADDRESS=udp://gazebo-px4:14540
DRONE_SYSTEM_ID=1
DRONE_COMPONENT_ID=1

# GPS Origin (Dodoma, Tanzania)
PX4_HOME_LAT=-6.1630
PX4_HOME_LON=35.7516
PX4_HOME_ALT=1120

# Logging
LOG_LEVEL=INFO
