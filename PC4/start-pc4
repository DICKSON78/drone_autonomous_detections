#!/bin/bash

# PC4 Quick Start Script
# Usage: ./start-pc4 [command]
# Commands: start, stop, restart, status, logs, test, setup

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

print_status() {
    echo -e "${GREEN}[PC4]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[PC4]${NC} $1"
}

print_error() {
    echo -e "${RED}[PC4]${NC} $1"
}

print_header() {
    echo -e "${BLUE}====================================${NC}"
    echo -e "${BLUE}PC4: Feedback Service${NC}"
    echo -e "${BLUE}====================================${NC}"
}

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Check if setup.sh exists
if [ ! -f "setup.sh" ]; then
    print_error "setup.sh not found in current directory"
    exit 1
fi

case "${1:-start}" in
    "start")
        print_header
        print_status "Starting PC4 services..."
        ./setup.sh setup
        ;;
    "stop")
        print_status "Stopping PC4 services..."
        ./setup.sh stop
        ;;
    "restart")
        print_status "Restarting PC4 services..."
        ./setup.sh restart
        ;;
    "status")
        print_status "PC4 service status:"
        ./setup.sh status
        ;;
    "logs")
        print_status "PC4 service logs:"
        ./setup.sh logs
        ;;
    "test")
        print_status "Testing PC4 services..."
        ./setup.sh test
        ;;
    "tts")
        print_status "Testing Text-to-Speech..."
        ./setup.sh tts
        ;;
    "setup")
        print_header
        print_status "Running full PC4 setup..."
        ./setup.sh setup
        ;;
    "help"|"-h"|"--help")
        echo "PC4 Quick Start Script"
        echo ""
        echo "Usage: ./start-pc4 [command]"
        echo ""
        echo "Commands:"
        echo "  start     - Start PC4 services (default)"
        echo "  stop      - Stop PC4 services"
        echo "  restart   - Restart PC4 services"
        echo "  status    - Show service status"
        echo "  logs      - Show service logs"
        echo "  test      - Test services"
        echo "  tts       - Test text-to-speech"
        echo "  setup     - Run full setup"
        echo "  help      - Show this help"
        echo ""
        echo "Examples:"
        echo "  ./start-pc4          # Start services"
        echo "  ./start-pc4 start    # Start services"
        echo "  ./start-pc4 stop     # Stop services"
        echo "  ./start-pc4 logs     # View logs"
        ;;
    *)
        print_error "Unknown command: $1"
        echo "Use './start-pc4 help' for usage information"
        exit 1
        ;;
esac
