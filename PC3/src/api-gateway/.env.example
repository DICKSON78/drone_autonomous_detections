# ==============================
# PC3 API Gateway Configuration
# ==============================

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# InfluxDB (PC3 local)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=drone-telemetry-token
INFLUXDB_ORG=drone-project
INFLUXDB_BUCKET=drone_telemetry

# Kafka (PC1 - Command & Flight Control)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=pc3-api-gateway
KAFKA_GROUP_ID=pc3-consumer-group

# Kafka Topics
KAFKA_TOPIC_GPS=drone.telemetry.gps
KAFKA_TOPIC_BATTERY=drone.telemetry.battery
KAFKA_TOPIC_ATTITUDE=drone.telemetry.attitude
KAFKA_TOPIC_FLIGHT=drone.telemetry.flight
KAFKA_TOPIC_DETECTIONS=drone.telemetry.detections
KAFKA_TOPIC_NAVIGATION=drone.telemetry.navigation
KAFKA_TOPIC_COMMANDS=drone.commands.flight
KAFKA_TOPIC_STATUS=drone.status.flight
KAFKA_TOPIC_ALERTS=drone.alerts.system

# WebSocket
WS_PORT=3002
WS_PING_INTERVAL=30000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Grafana (for proxy)
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# Telemetry Collector (Python service)
TELEMETRY_COLLECTOR_URL=http://localhost:8004

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
