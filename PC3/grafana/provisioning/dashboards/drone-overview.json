      "targets": [
        {
          "refId": "A",
          "expr": "from(bucket: \"drone-telemetry\")\n  |> range($range)\n  |> filter(fn: (r) => r._measurement == \"flight_telemetry\")\n  |> last()\n  |> yield(key: r._field, value: r._value)",
